DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Local dev toggle
USE_SQLITE=true

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=wordduel
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
